# ============================================
# KLARY Backend Environment Configuration
# Copy to .env and fill in your values
# ============================================

# Server
NODE_ENV=development
PORT=4000
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://klary_user:klary_password@localhost:5432/klary_db?schema=public"

# Security
JWT_SECRET=change-this-to-a-64-character-random-string-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# OpenAI (for AI transaction categorization)
OPENAI_API_KEY=sk-your-openai-api-key

# Twilio (for SMS document requests)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+46701234567

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/klary.log

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# Accounting Software API Keys (for integrations)
FORTNOX_CLIENT_ID=your-fortnox-client-id
FORTNOX_CLIENT_SECRET=your-fortnox-client-secret
VISMA_CLIENT_ID=your-visma-client-id
VISMA_CLIENT_SECRET=your-visma-client-secret
ECONOMIC_APP_ID=your-economic-app-id
ECONOMIC_APP_SECRET=your-economic-app-secret
TRIPLETEX_CONSUMER_TOKEN=your-tripletex-token
TRIPLETEX_EMPLOYEE_TOKEN=your-tripletex-employee-token